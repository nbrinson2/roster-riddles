{
  "name": "roster-riddles",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node index.js",
    "dev": "nodemon index.js",
    "frontend": "ng serve --port 4300 --open",
    "backend": "nodemon index.js",
    "dev:fullstack": "concurrently \"npm run frontend\" \"npm run backend\"",
    "build": "ng build",
    "build:prod": "node scripts/generate-env-prod.mjs && ng build --configuration production",
    "build:staging": "DEPLOYMENT=staging node scripts/generate-env-prod.mjs && ng build --configuration staging",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:firestore-rules": "firebase emulators:exec --only firestore --project roster-riddles-457600 \"node ./scripts/verify-firestore-rules.mjs\"",
    "test:server": "node --test \"server/*.test.js\" && node ./scripts/seed-weekly-contest-staging.mjs ./docs/fixtures/weekly-contest-staging.example.json --dry-run",
    "rebuild:leaderboard-snapshots": "node scripts/rebuild-leaderboard-snapshots.mjs",
    "test:stats-emulator": "firebase emulators:exec --only firestore --project roster-riddles-457600 \"node ./scripts/verify-stats-aggregate-emulator.mjs\"",
    "test:stats-concurrency": "firebase emulators:exec --only firestore --project roster-riddles-457600 \"node ./scripts/stats-concurrency-load-test.mjs\"",
    "verify:stats-reconciliation": "node ./scripts/verify-stats-reconciliation.mjs",
    "verify:leaderboard-cohort": "node ./scripts/verify-leaderboard-cohort.mjs",
    "seed:weekly-contest-staging": "node ./scripts/seed-weekly-contest-staging.mjs",
    "admin:set-claim": "node ./scripts/set-admin-claim.mjs",
    "mirror:firestore-cache": "node ./scripts/mirror-firestore-cache.mjs",
    "deploy:firestore:staging": "firebase deploy --only \"firestore:(default)\" --project roster-riddles-staging",
    "deploy:firestore:staging:rules": "firebase deploy --only \"firestore:rules,firestore:(default)\" --project roster-riddles-staging",
    "deploy:firestore:staging:indexes": "firebase deploy --only \"firestore:indexes,firestore:(default)\" --project roster-riddles-staging",
    "deploy:firestore:prod": "firebase deploy --only firestore:roster-riddles --project roster-riddles-457600",
    "deploy:firestore:prod:rules": "firebase deploy --only \"firestore:rules,firestore:roster-riddles\" --project roster-riddles-457600",
    "deploy:firestore:prod:indexes": "firebase deploy --only \"firestore:indexes,firestore:roster-riddles\" --project roster-riddles-457600"
  },
  "type": "module",
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.8",
    "@angular/cdk": "^18.2.14",
    "@angular/common": "^19.2.8",
    "@angular/compiler": "^19.2.8",
    "@angular/core": "^19.2.8",
    "@angular/fire": "^19.1.0",
    "@angular/forms": "^19.2.8",
    "@angular/material": "^18.2.14",
    "@angular/platform-browser": "^19.2.8",
    "@angular/platform-browser-dynamic": "^19.2.8",
    "@angular/router": "^19.2.8",
    "auth-guard": "^1.0.12",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "firebase": "^11.6.1",
    "firebase-admin": "^13.8.0",
    "rxjs": "~7.8.1",
    "stripe": "^17.7.0",
    "tslib": "^2.4.0",
    "zod": "^3.24.2",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.9",
    "@angular/cli": "~19.2.9",
    "@angular/compiler-cli": "^19.2.8",
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/jasmine": "~4.3.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "firebase-tools": "^13.35.0",
    "jasmine-core": "~5.1.2",
    "karma": "~6.4.1",
    "karma-chrome-launcher": "~3.1.1",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "nodemon": "^3.1.10",
    "typescript": "~5.8.3"
  },
  "description": "This project was generated with [Angular CLI](https://github.com/angular/angular-cli) version 18.0.0.",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
