rules_version = '2';
// Deploy: `firebase deploy --only firestore:(default)|firestore:roster-riddles` per `firebase.json`.

service cloud.firestore {
  match /databases/{database}/documents {

    // Public read caches (writes only from Admin SDK / Cloud Functions)
    match /cache/{docId} {
      allow read: if docId == 'mlb_players_snapshot'
        || docId == 'career_path_players_snapshot_meta'
        || docId == 'career_path_players_snapshot'
        || docId.matches('^career_path_shard_[0-9]+$')
        || docId == 'mlb_nicknames';
      allow write: if false;
    }

    // Profiles: only the signed-in user may access `users/{uid}` (equivalent to auth.uid == path uid).
    // Stripe Connect payout fields (P6-B2+): server / Admin SDK only — see docs/weekly-contests/weekly-contests-schema-users-payouts.md (P6-C1).
    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId
        && !request.resource.data.keys().hasAny([
          'stripeConnectAccountId',
          'stripeConnectAccountType',
          'stripeConnectCreatedAt',
          'stripeConnectChargesEnabled',
          'stripeConnectPayoutsEnabled',
          'stripeConnectDetailsSubmitted',
          'stripeConnectRequirementsCurrentlyDueCount',
          'stripeConnectRequirementsCurrentlyDueSummary',
          'stripeConnectLastWebhookEventId',
          'stripeConnectLastAccountUpdatedAt',
          'stripePayoutLastWebhookEventId',
          'stripePayoutLastWebhookType',
          'stripePayoutLastWebhookAt',
          'stripePayoutLastFailurePublicCode',
        ]);
      allow update: if signedIn() && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).changedKeys().hasAny([
          'stripeConnectAccountId',
          'stripeConnectAccountType',
          'stripeConnectCreatedAt',
          'stripeConnectChargesEnabled',
          'stripeConnectPayoutsEnabled',
          'stripeConnectDetailsSubmitted',
          'stripeConnectRequirementsCurrentlyDueCount',
          'stripeConnectRequirementsCurrentlyDueSummary',
          'stripeConnectLastWebhookEventId',
          'stripeConnectLastAccountUpdatedAt',
          'stripePayoutLastWebhookEventId',
          'stripePayoutLastWebhookType',
          'stripePayoutLastWebhookAt',
          'stripePayoutLastFailurePublicCode',
        ]);
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    // Gameplay events: append-only via Admin SDK / Express — clients may read own events only.
    match /users/{userId}/gameplayEvents/{eventId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    // Aggregates: written only by trusted backends (Admin SDK). Clients may read own stats doc(s).
    match /users/{userId}/stats/{docId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    // Weekly contests (Phase 4 B1): `contests/{contestId}` — signed-in read; unauthenticated may read
    // `status == 'open'` only (so clients can tell if weekly contests exist without signing in).
    match /contests/{contestId} {
      allow read: if signedIn() || resource.data.status == 'open';
      allow create, update, delete: if false;
    }

    // Weekly contests (Phase 4 B2 + Phase 5 P5-B1 / P5-G1): `contests/{contestId}/entries/{uid}` — read own entry only;
    // all client writes denied (join + Stripe webhooks use Admin SDK). That includes Phase 5 payment fields
    // (`paymentStatus`, `stripe*`, `paidAt`, `entryFeeCentsSnapshot`, `refundedAmountCents`, `lastStripeEventId`) — never client-writable.
    match /contests/{contestId}/entries/{entryUid} {
      allow read: if signedIn() && request.auth.uid == entryUid;
      allow create, update, delete: if false;
    }

    // Phase 4 B3 + Phase 6 P6-C2: immutable `results/*` and `payouts/*` (`dryRun`, `final`, optional `run_*`) — signed-in read; Admin SDK writes only.
    match /contests/{contestId}/results/{resultDocId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }
    match /contests/{contestId}/payouts/{payoutDocId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    // Phase 4 optional materialized live standings — **no client access**. Prefer HTTP
    // `GET /api/v1/contests/:contestId/leaderboard` only; widening reads here would duplicate
    // policy and bypass server rate limits / cache. Admin SDK / workers may write; lifecycle
    // deletes this subtree when the contest leaves `open` (see contest-live-standings-artifacts.js).
    match /contests/{contestId}/liveStandings/{docId} {
      allow read, write: if false;
    }

    // Phase 5 P5-E1 / P5-G1: per-contest Stripe PI settlement markers (webhook idempotency aid) — Admin SDK only.
    match /contests/{contestId}/stripePiSettlements/{paymentIntentId} {
      allow read, write: if false;
    }

    // Any other contest subpaths — deny clients.
    match /contests/{contestId}/{document=**} {
      allow read, write: if false;
    }
    match /contestEntries/{document=**} {
      allow read, write: if false;
    }
    match /ledgers/{document=**} {
      allow read, write: if false;
    }

    // Phase 5 P5-B2 / P5-G1: append-only payment ledger — Admin SDK only (no client read or write).
    match /ledgerEntries/{ledgerEntryId} {
      allow read, write: if false;
    }

    // Phase 5 P5-E1 / P5-G1: Stripe webhook idempotency docs — Admin SDK only (no client read or write).
    match /processedStripeEvents/{eventId} {
      allow read, write: if false;
    }

    // Precomputed leaderboards (Phase 3): one doc per board under snapshots/boards (even path segments).
    // Other paths under leaderboards/ have no rule → denied by default.
    match /leaderboards/snapshots/boards/{boardId} {
      allow read: if boardId in [
        'global',
        'bio-ball',
        'career-path',
        'nickname-streak',
      ];
      allow create, update, delete: if false;
    }

    // Game caches: public read; writes only via jobs / Admin SDK.
    match /cache/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

function signedIn() {
  return request.auth != null;
}
