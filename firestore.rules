rules_version = '2';
// Target database id: roster-riddles (matches Angular `initializeFirestore(..., 'roster-riddles')`).
// Deploy: Firebase Console → Firestore → select database "roster-riddles" → Rules,
// or: firebase deploy --only firestore:roster-riddles (with firebase.json below).

service cloud.firestore {
  match /databases/{database}/documents {

    // Profiles: only the signed-in user may access `users/{uid}` (equivalent to auth.uid == path uid).
    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
      allow update, delete: if signedIn() && request.auth.uid == userId;
    }

    // Gameplay events: append-only via Admin SDK / Express — clients may read own events only.
    match /users/{userId}/gameplayEvents/{eventId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    // Aggregates: written only by trusted backends (Admin SDK). Clients may read own stats doc(s).
    match /users/{userId}/stats/{docId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    // Weekly contests (Phase 4 B1): `contests/{contestId}` — signed-in read; writes via Admin SDK only.
    match /contests/{contestId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    // Subpaths (entries, results, payouts, …) — Stories B2+; deny clients until those rules ship.
    match /contests/{contestId}/{document=**} {
      allow read, write: if false;
    }
    match /contestEntries/{document=**} {
      allow read, write: if false;
    }
    match /ledgers/{document=**} {
      allow read, write: if false;
    }

    // Precomputed leaderboards (Story B2): one doc per board under snapshots/boards (even path segments).
    // Story F1: request rate limits are enforced in Express, not in rules (Firestore has no per-IP RPS primitive).
    // Other paths under leaderboards/ have no rule → denied by default.
    match /leaderboards/snapshots/boards/{boardId} {
      allow read: if boardId in [
        'global',
        'bio-ball',
        'career-path',
        'nickname-streak',
      ];
      allow create, update, delete: if false;
    }

    // Game caches: public read; writes only via jobs / Admin SDK.
    match /cache/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}

function signedIn() {
  return request.auth != null;
}
