# Copy to `.env` in the repo root (never commit `.env`).
# Express loads this automatically via `import 'dotenv/config'` in `index.js`.

# ‚îÄ‚îÄ Firebase Admin (local dev = staging project `roster-riddles-staging`) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# Use ONE of these so `GET /api/v1/me` verifies the same tokens as the Angular app.
# `GET /api/v1/me` returns `isAdmin` from the ID token custom claim `admin: true` (see docs/admin-dashboard-security.md).
# Grant/revoke that claim: docs/admin-dashboard-ops-ad3.md ‚Äî npm run admin:set-claim -- <uid> --grant|--revoke
#
# Option A (recommended): path to the JSON key file from Firebase Console:
#   Firebase ‚Üí Project settings ‚Üí Service accounts ‚Üí Generate new private key
#   Save as e.g. `secrets/roster-riddles-staging-adminsdk.json` (folder is gitignored).
#
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/roster-riddles-staging-adminsdk.json
#
# Option B: inline JSON (single line) ‚Äî useful for some hosts; avoid in shared shells.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"roster-riddles-staging",...}

# Optional: override port (default 3000). Angular `proxy.conf.json` proxies /api here.
# PORT=3000

# ‚îÄ‚îÄ Story F1 ‚Äî API rate limits (see docs/leaderboards-rate-limits-f1.md) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# LEADERBOARD_RATE_LIMIT_MAX=90
# LEADERBOARD_RATE_LIMIT_WINDOW_MS=60000
# GAMEPLAY_EVENT_RATE_LIMIT_MAX=30
# GAMEPLAY_EVENT_RATE_LIMIT_WINDOW_MS=60000
# Story C1 ‚Äî POST /api/v1/contests/:contestId/join (per uid; see docs/weekly-contests-api-c1.md)
# CONTEST_JOIN_RATE_LIMIT_MAX=30
# CONTEST_JOIN_RATE_LIMIT_WINDOW_MS=60000
# Story D2 ‚Äî GET /api/v1/contests (per uid; see docs/weekly-contests-api-d2.md)
# CONTEST_READ_RATE_LIMIT_MAX=120
# CONTEST_READ_RATE_LIMIT_WINDOW_MS=60000
# TRUST_PROXY_FOR_RATE_LIMIT=true
# RATE_LIMITS_DISABLED=true

# ‚îÄ‚îÄ Story D1 ‚Äî contest status transitions (see docs/weekly-contests-ops-d1.md) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# CONTESTS_OPERATOR_SECRET=long-random-string
# Or point at a gitignored file (one line, UTF-8): CONTESTS_OPERATOR_SECRET=./secrets/contests-operator-secret.txt
# Cloud Scheduler or operator curl: POST /api/internal/v1/contests/:contestId/transition
# Weekly contests Story F2 (paid‚Üícancelled|scoring, force:true): docs/weekly-contests-ops-f2.md ‚Äî same secret.

# ‚îÄ‚îÄ Story E1 ‚Äî close due windows + optional scoring webhook (see docs/weekly-contests-ops-e1.md)
# CONTEST_WINDOW_CRON_SECRET=long-random-string
# CONTEST_CLOSE_WINDOW_BATCH_SIZE=25
#
# After E1 moves a contest to `scoring`, it can POST to run-scoring (E2). Use the public URL your
# Express app serves (not localhost unless the caller runs on the same host).
# CONTEST_SCORING_WEBHOOK_URL=https://api.example.com/api/internal/v1/contests/run-scoring
#
# Bearer sent to run-scoring must match getContestsOperatorOrCronSecret(): CONTEST_WINDOW_CRON_SECRET
# if set, otherwise CONTESTS_OPERATOR_SECRET. So set CONTEST_SCORING_WEBHOOK_SECRET to that same
# string (often identical to CONTESTS_OPERATOR_SECRET when you omit CONTEST_WINDOW_CRON_SECRET).
# CONTEST_SCORING_WEBHOOK_SECRET=match-cron-or-operator-secret-above

# ‚îÄ‚îÄ Story F2 ‚Äî verified email to appear on leaderboard (see docs/leaderboards-duplicate-accounts-f2.md)
# Omit or true in production. Set false only for QA/staging test accounts.
# LEADERBOARD_REQUIRE_EMAIL_VERIFIED=false

# ‚îÄ‚îÄ Story G2 ‚Äî ops / emergency (see docs/leaderboards-runbook.md) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# When true, GET /api/v1/leaderboards returns 503 (internal snapshot rebuild still allowed).
# LEADERBOARDS_DISABLED=true
#
# Angular: hide leaderboard sidenav panel ‚Äî set at `npm run build:staging` / `build:prod`
# via LEADERBOARDS_UI_ENABLED=false (see scripts/generate-env-prod.mjs), not this file.
#
# Story AD-4 ‚Äî hide admin dashboard entry in the Angular bundle: set at Docker/Cloud Build
# `ADMIN_DASHBOARD_UI_ENABLED=false` (same script). Local `ng serve` uses `src/environment.ts`
# (`adminDashboardUiEnabled`); set `false` there to simulate the flag off.

# Firestore database id ‚Äî must match the Angular app (`environment.firestoreDatabaseId`).
# Omit or `(default)` for staging/local; production often uses `roster-riddles`.
# FIRESTORE_DATABASE_ID=(default)

# ‚îÄ‚îÄ One-time: mirror Firestore `cache` from prod ‚Üí staging (see docs/firestore-mirror.md) ‚îÄ
# MIRROR_SOURCE_CREDENTIALS=./secrets/prod-service-account.json
# MIRROR_TARGET_CREDENTIALS=./secrets/roster-riddles-staging-adminsdk.json
# SOURCE_FIRESTORE_DATABASE_ID=roster-riddles
# TARGET_FIRESTORE_DATABASE_ID=

# ‚îÄ‚îÄ Stripe (test keys only for local dev; see docs/stripe.md) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# STRIPE_SECRET_KEY=sk_test_...          # Express ‚Äî never commit; prod uses sk_live via Secret Manager
# STRIPE_PUBLISHABLE_KEY=pk_test_...    # Optional local ‚Äî usually baked at ng build from CI for staging/prod
